#TN Begin modify by linhong.han/860549 20231206 CR/EKFOGO4G-9172
service tn_checksum_elabel /vendor/bin/tn_checksum_elabel.sh
   user system
   group root system
   disabled
#TN End modify by linhong.han/860549 20231206 CR/EKFOGO4G-9172

service tlcKeyboxSample /vendor/bin/tlcKeyboxSample
    user system
    group system
    oneshot

#on post-fs-data
on property:vendor.attestation.rewrite=1
    start tlcKeyboxSample

#TN Begin modify for mount /mnt/vendor/elabel/regulatory_info.png by yang.chen/860621 20230901 CR/EKFOGO4G-1375
on boot
   chown system system /mnt/elabel/regulatory_info.png
   chmod 0664 /mnt/elabel/regulatory_info.png

   restorecon_recursive /mnt/elabel

#TN End modify for mount /mnt/vendor/elabel/regulatory_info.png by yang.chen/860621 20230901 CR/EKFOGO4G-1375
