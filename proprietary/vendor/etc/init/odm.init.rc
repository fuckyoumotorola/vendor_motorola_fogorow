    chown system root /sys/bus/i2c/drivers/awinic_sar/3-0012/aot
#TN modified by bingtai.zou/860558 20230908 EKFOGO4G-1867 END

#TN Begin modify by linhong.han/860549 20231206 CR/EKFOGO4G-9172
    start tn_checksum_elabel

on property:persist.vendor.elabel.stop_check=1
    stop tn_checksum_elabel
    setprop persist.vendor.elabel.stop_check 0
#TN End modify by linhong.han/860549 20231206 CR/EKFOGO4G-9172

#TN Begin modify by bingtai.zou begin
on property:persist.vendor.proxcal.status=1
    write /sys/class/sensor/m_ps_misc/proxcali 1
    setprop persist.vendor.proxcal.status 0
